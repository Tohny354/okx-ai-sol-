# ========== OKX ==========
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# true = 模拟盘；false = 实盘
OKX_SIMULATED=true

# 网络：DNS 解析不了 www.okx.com 时，填你本地代理（常见 Clash / V2：7890）
# 示例：http://127.0.0.1:7890
HTTP_PROXY=
HTTPS_PROXY=

# 经代理访问欧易时若报 SSL EOF，可适当加大超时与重试次数
OKX_TIMEOUT=30
OKX_RETRIES=4

# ========== 策略 ==========
# K 线周期（欧易 bar：1m 3m 5m 15m 30m 1H 2H 4H 等）与根数（最大约 500，单次 candles 最多 300，不足会走 history-candles）
CANDLE_BAR=15m
CANDLE_LIMIT=200

# 多周期（供 AI_USER_RULE 中日线/4H/48h 等规则）：日线根数需 >=36 才能算 30 日均线与斜率
DAILY_CANDLE_LIMIT=45
H4_CANDLE_LIMIT=120
H1_CANDLE_LIMIT=60

INST_ID=BTC-USDT-SWAP
TD_MODE=isolated
LEVER=5
ORDER_SIZE=0.01
CHECK_INTERVAL_SEC=30
DRY_RUN=true

# 止盈/止损百分比（相对开仓均价）
TAKE_PROFIT_PCT=0.015
STOP_LOSS_PCT=0.008

# ========== AI（可选）==========
USE_AI=false
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# 可选：官方 OpenAI 在你所在地区若 403，可填兼容接口，例如 DeepSeek：
# OPENAI_BASE_URL=https://api.deepseek.com

AI_USER_RULE=
